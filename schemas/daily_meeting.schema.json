{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/daily_meeting.schema.json",
  "title": "Daily meeting structured data",
  "type": "object",
  "required": [
    "meeting_id",
    "date",
    "timezone",
    "team",
    "summary",
    "participants",
    "updates",
    "decisions",
    "action_items",
    "topics",
    "offtopic"
  ],
  "additionalProperties": false,
  "properties": {
    "meeting_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"
    },
    "date": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "minLength": 1 },
    "team": { "type": "string", "minLength": 1 },
    "participants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": { "type": "string", "minLength": 1 },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["person", "done", "todo", "blockers", "notes"],
        "additionalProperties": false,
        "properties": {
          "person": { "type": "string", "minLength": 1 },
          "done": { "type": "array", "items": { "type": "string" } },
          "todo": { "type": "array", "items": { "type": "string" } },
          "blockers": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "decisions": { "type": "array", "items": { "type": "string" } },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task", "owner", "status", "due_date"],
        "additionalProperties": false,
        "properties": {
          "task": { "type": "string", "minLength": 1 },
          "owner": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["open", "in_progress", "done", "dropped"]
          },
          "due_date": { "type": ["string", "null"], "format": "date" }
        }
      }
    },
    "topics": { "type": "array", "items": { "type": "string" } },
    "offtopic": { "type": "array", "items": { "type": "string" } }
  }
}
